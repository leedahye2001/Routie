meta {
  name: 회원가입
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/register
  body: json
  auth: none
}

body:json {
  {
    "email": "test@test.com",
    "password": "password123",
    "nickname": "테스터"
  }
}

script:post-response {
  if (res.status === 201 || res.status === 200) {
    bru.setEnvVar("accessToken", res.body.accessToken);
  }
}
